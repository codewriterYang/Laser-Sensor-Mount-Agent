# LLM Configuration
# Copy to .env and fill in your actual keys.

# Language Model — text generation, prompt optimization
# DeepSeek-V4-flash（火山引擎）
LLM_MODEL=ep-20260612121623-2g5tp
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=your_api_key_here

# Image Model — assembly diagram generation (Epic-3+)
# doubao-seedream-4.5（火山引擎）
IMAGE_MODEL=ep-20260612121942-wn9qn
IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
IMAGE_API_KEY=your_api_key_here

# Switching Rules:
#   - Change MODEL name to switch models
#   - Change BASE_URL / API_KEY to switch providers
#   - All providers must be OpenAI SDK compatible
